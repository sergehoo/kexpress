# Frontend Kexpress — copier en .env.local et adapter.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8009/api

# --- SSO Keycloak (OIDC) ---------------------------------------------------
# Laisser VIDE pour désactiver le SSO (connexion locale par mot de passe).
# Renseigner l'autorité du realm pour activer le bouton « Se connecter avec le SSO ».
# NEXT_PUBLIC_OIDC_AUTHORITY=https://auth.datarium-dev.com/realms/kexpress
# NEXT_PUBLIC_OIDC_CLIENT_ID=kexpress-web
# Masquer l'accès secours local (mettre "false") :
# NEXT_PUBLIC_LOCAL_LOGIN=true
