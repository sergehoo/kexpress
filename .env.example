# Copier en .env et adapter. Ne jamais committer .env.
DEBUG=True
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://sergeogah@127.0.0.1:5433/kexpress
CORS_ALLOWED_ORIGINS=http://localhost:3000
# PostGIS / GeoDjango : la base doit être PostGIS (image postgis/postgis en Docker).
# Libs natives auto-détectées sous Linux ; sous macOS Homebrew les chemins par défaut
# (/opt/homebrew/lib) sont réglés dans settings/local.py — surchargeables ici :
# GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib
# --- SSO Keycloak (OIDC) ---------------------------------------------------
# Activer pour que Django valide les jetons Keycloak (resource server).
# OIDC_ENABLED=True
# OIDC_ISSUER=https://auth.datarium-dev.com/realms/kexpress
# OIDC_CLIENT_ID=kexpress-web
# OIDC_AUDIENCE=            # vide = on vérifie azp/client ; sinon liste d'audiences exigées
# OIDC_DEFAULT_ROLE=requester
# LOCAL_LOGIN_ENABLED=True  # accès de secours mot de passe (super-admin) quand OIDC actif

# K-BOT LLM (optionnel) : si défini, active les réponses libres via Claude (RAG ancré).
# ANTHROPIC_API_KEY=sk-ant-...
# KBOT_MODEL=claude-3-5-sonnet-latest

# Web Push (VAPID) — générer avec py_vapid
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_ADMIN_EMAIL=admin@example.com
