# =============================================================================
# Kaydan Express — variables d'environnement de PRODUCTION
# Copier ces clés dans l'onglet « Environment » de Dokploy (ou un .env non versionné).
# Ne JAMAIS committer de vrais secrets.
# =============================================================================

# --- Django (obligatoire) ---------------------------------------------------
# Générer : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changez-moi-en-une-cle-longue-et-aleatoire
# Domaines publics (séparés par des virgules), sans schéma.
ALLOWED_HOSTS=app.exemple.com,api.exemple.com
# Origines de confiance CSRF (avec schéma https).
CSRF_TRUSTED_ORIGINS=https://app.exemple.com,https://api.exemple.com
# Origines autorisées pour le navigateur (frontend → API).
CORS_ALLOWED_ORIGINS=https://app.exemple.com

# --- Base de données (PostgreSQL géré par le service db) --------------------
POSTGRES_DB=kexpress
POSTGRES_USER=kexpress
POSTGRES_PASSWORD=changez-moi-mot-de-passe-postgres

# --- Frontend (figé au BUILD de l'image Next.js) ----------------------------
# Doit pointer vers le domaine backend (provisionné dans Dokploy) suffixé par /api,
# TOUJOURS en https en production (sinon mixed-content : XHR/WS bloqués par le navigateur).
# Le WebSocket en est dérivé automatiquement (wss://api.exemple.com/ws/...).
# ⚠ Variable figée à la compilation : si elle change, reconstruire le frontend
#   (Dokploy : « Rebuild » ; en local : docker compose up --build frontend).
NEXT_PUBLIC_API_BASE=https://api.exemple.com/api

# --- Superutilisateur initial (créé au 1er démarrage, optionnel) ------------
DJANGO_SUPERUSER_EMAIL=admin@exemple.com
DJANGO_SUPERUSER_PASSWORD=changez-moi-mot-de-passe-admin

# --- Données de démonstration (laisser false en production) -----------------
SEED_DEMO=false

# --- Web Push (VAPID) — générer avec py_vapid -------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@exemple.com

# --- Notifications email (SMTP) ---------------------------------------------
NOTIFY_EMAIL_ENABLED=False
DEFAULT_FROM_EMAIL=noreply@exemple.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- K-BOT (assistant IA, optionnel) ----------------------------------------
# Sans clé, K-BOT bascule sur le moteur heuristique ancré sur les données.
ANTHROPIC_API_KEY=
KBOT_MODEL=claude-3-5-sonnet-latest

# --- Carte / routage & Fuel Intelligence ------------------------------------
OSRM_URL=https://router.project-osrm.org
MAP_COST_PER_KM=350.0
FUEL_PRICE_SOURCE_URL=
FUEL_PRICE_SUPER=875
FUEL_PRICE_GASOIL=655
REVISION_ALERT_PCTS=20,10,5

# --- Réglages avancés (optionnels) ------------------------------------------
# Laisser False si Traefik gère déjà la redirection HTTPS.
SECURE_SSL_REDIRECT=False
# HSTS : mettre SECURE_HSTS_SECONDS=0 le temps de valider le certificat TLS.
SECURE_HSTS_SECONDS=2592000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
# Connexions PostgreSQL persistantes (secondes).
CONN_MAX_AGE=60
# SMTP en TLS implicite (port 465) ; laisser False avec EMAIL_USE_TLS=True (587).
EMAIL_USE_SSL=False
LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
